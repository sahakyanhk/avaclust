#!/bin/bash
set -euo pipefail

WD="$(cd "$(dirname "$0")" && pwd)"

# ── Defaults ──
PDBDIR=""
OUTDIR="rnpclust_out"
CUTOFF="auto"
ICUTOFF=""
METHOD=0   # 0 = hierarchical (default), 1 = set_cover
THREADS=""
CHAINS="A,B"

usage() {
  cat >&2 <<EOF
Usage: $(basename "$0") -i <pdb_dir> [-o <output_dir>] [-c <cutoff>] [-m <method>] [-I <interface_cutoff>] [-a <chains>] [-t <threads>]

Options:
  -i  Input directory with .pdb files (required)
  -o  Output directory (default: rnpclust_out)
  -c  TM-score cutoff (default: auto)
      method 0: optional — cuts dendrogram at 1-cutoff; omit for auto-detection
      method 1: required — threshold for set-cover graph edges
  -I  Cutoff in Angstroms for extracting interface residues between chains
  -m  Clustering method (default: 0)
        0 = hierarchical clustering (auto k or cutoff-based)
        1 = greedy set-cover clustering (requires -c cutoff)
  -a  Chains to consider for alignment (default: A,B)
  -t  Number of threads for parallel USalign (default: all cores)
  -h  Show this help
EOF
  exit 1
}

while getopts "i:o:c:m:I:t:a:h" opt; do
  case "$opt" in
    i) PDBDIR="${OPTARG%/}" ;;
    o) OUTDIR="${OPTARG%/}" ;;
    c) CUTOFF="$OPTARG" ;;
    I) ICUTOFF="$OPTARG" ;;
    m) METHOD="$OPTARG" ;;
    t) THREADS="$OPTARG" ;;
    a) CHAINS="$OPTARG" ;;
    h) usage ;;
    *) usage ;;
  esac
done

[[ -z "$PDBDIR" ]] && { echo "ERROR: -i <pdb_dir> is required" >&2; usage; }
[[ -d "$PDBDIR" ]] || { echo "ERROR: $PDBDIR is not a directory" >&2; exit 1; }

if [[ "$METHOD" == "1" && "$CUTOFF" == "auto" ]]; then
  echo "ERROR: set-cover clustering (-m 1) requires a cutoff (-c <value>)" >&2
  exit 1
fi

echo "PDB dir:    $PDBDIR" >&2
echo "Output dir: $OUTDIR" >&2
echo "Method:     $( [[ "$METHOD" == "0" ]] && echo "hierarchical" || echo "set-cover" )" >&2
echo "Cutoff:     $CUTOFF" >&2
echo "ICutoff:    $ICUTOFF" >&2
echo "Chains:     $CHAINS" >&2
echo "Threads:    ${THREADS:-$(nproc)}" >&2


mkdir -p "$OUTDIR"


if [ -n "$ICUTOFF" ]; then
  echo "=== Extracting interface residues with cutoff $ICUTOFF Å ===" >&2
  python "$WD/extract_interface.py" -i "$PDBDIR" -c "$CHAINS" --cut "$ICUTOFF" -o "${PDBDIR}_i${ICUTOFF}"
  PDBDIR="${PDBDIR}_i${ICUTOFF}"
fi


# ── All-vs-all alignments ──
allvsall="$OUTDIR/all_vs_all.tsv"
nstructs=$(find "$PDBDIR" -maxdepth 1 -name '*.pdb' | wc -l)
expected_lines=$(( nstructs * (nstructs - 1) / 2 + 1 ))  # pairs + header

if [[ -f "$allvsall" ]] && (( $(wc -l < "$allvsall") == expected_lines )); then
  echo "=== Reusing existing $allvsall ($expected_lines lines) ===" >&2
else
  echo "=== Running all-vs-all alignments ===" >&2
  bash "$WD/usalign_all_vs_all.bash" "$PDBDIR" "$allvsall" "$CHAINS" "$THREADS"
fi


python - <<EOF

import pandas as pd
from matplotlib import pyplot as plt

df = pd.read_csv("$allvsall", sep='\t')
plt.style.use('bmh')
plt.figure(figsize=(10, 4))
plt.hist(df.TM, bins=50, alpha=0.8, label='cutoff=${CUTOFF}')
plt.xlim(0, 1)
plt.xlabel('TM Score')
plt.ylabel('Frequency')
plt.title('Distribution of TM Scores')
plt.savefig('${OUTDIR}/all_vs_all.png')

EOF


# ── Clustering ──
if [[ "$METHOD" == "0" ]]; then
  cutoff_args=()
  if [[ "$CUTOFF" != "auto" ]]; then
    echo "=== Hierarchical clustering (cutoff=$CUTOFF) ===" >&2
    cutoff_args=(--cutoff "$CUTOFF")
  else
    echo "=== Hierarchical clustering (auto k) ===" >&2
  fi
  python "$WD/hierarchical_cluster.py" "$allvsall" \
                                  --col 2 \
                                  "${cutoff_args[@]}" \
                                  --optimal-leaf-order \
                                  --pdb-dir "$PDBDIR" \
                                  -o "$OUTDIR/clusters.dat" \
                                  -sc "$OUTDIR/aligned_clusters"

  echo "=== Plotting tree + heatmap ===" >&2
  python "$WD/plot_clustermap.py" "$OUTDIR/clusters_tree.nwk" \
                                  "$OUTDIR/clusters_matrix.tsv" \
                                  -o "$OUTDIR/clustermap.png"
else
  echo "=== Set-cover clustering (cutoff=$CUTOFF) ===" >&2
  python "$WD/setcover_cluster.py" "$allvsall" \
                                  --col 2 \
                                  --cutoff "$CUTOFF" \
                                  --centroid \
                                  --fmt wide \
                                  --pdb-dir "$PDBDIR" \
                                  -o "$OUTDIR/clusters.dat" \
                                  -sc "$OUTDIR/aligned_clusters"
fi
